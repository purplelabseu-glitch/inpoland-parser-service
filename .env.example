# Скопируйте PROXY_* / PROXY_REFRESH_URL с mobilede-parser-service (.env на VPS).
# Этот сервис — отдельный процесс на порту 8001, mobile.de не трогает.

PROXY_URL=http://user:password@proxy-host:port
# PROXY_POOL=
# PROXY_REFRESH_URL=https://api.asocks.com/proxy/<id>/refresh-ip
BROWSER_MAX_RETRIES=3
REFRESH_WAIT_S=4

# auto = сначала Camoufox, при CF/пустой странице — Chromium
BROWSER_ENGINE=auto
BROWSER_HEADLESS=true
BROWSER_LOCALE=ru-RU
NAV_TIMEOUT_MS=60000
CHALLENGE_WAIT_S=45
BROWSER_CONCURRENCY=1

COLLECT_MAX_PAGES_DEFAULT=10
COLLECT_MAX_PAGES_LIMIT=20

# openssl rand -hex 32
API_KEY=

LOG_LEVEL=INFO
